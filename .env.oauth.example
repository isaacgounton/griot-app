# OAuth Configuration Template
# Copy these to your .env file and fill in your credentials

# Base URLs (required for OAuth callbacks)
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# JWT Secret (use one of these)
JWT_SECRET_KEY=your-secret-key-at-least-32-characters-long
# Or:
# BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# ============================================
# Google OAuth (Sign in with Google)
# ============================================
# Get credentials from: https://console.cloud.google.com/
# 1. Create project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID
# 4. Set redirect URI: http://localhost:8000/api/v1/auth/oauth/google/callback

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ============================================
# GitHub OAuth (Sign in with GitHub)
# ============================================
# Get credentials from: https://github.com/settings/developers
# 1. New OAuth App
# 2. Set callback URL: http://localhost:8000/api/v1/auth/oauth/github/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# Discord OAuth (Sign in with Discord)
# ============================================
# Get credentials from: https://discord.com/developers/applications
# 1. New Application
# 2. OAuth2 section
# 3. Add redirect: http://localhost:8000/api/v1/auth/oauth/discord/callback

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ============================================
# Production URLs (update for deployment)
# ============================================
# BASE_URL=https://api.your-domain.com
# FRONTEND_URL=https://your-domain.com

# Update OAuth redirect URIs in provider consoles to:
# - https://api.your-domain.com/api/v1/auth/oauth/google/callback
# - https://api.your-domain.com/api/v1/auth/oauth/github/callback
# - https://api.your-domain.com/api/v1/auth/oauth/discord/callback
