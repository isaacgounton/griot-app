# Frontend API Configuration
# This file shows the environment variables that can be used to configure the frontend

# API Base URL (optional)
# In development with Vite dev server, this is automatically proxied to /api/v1
# In production, set this to point to your backend server
# Example: VITE_API_BASE_URL=https://api.example.com/api/v1
# Example: VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=

# Development mode (usually set automatically)
# VITE_DEV=true
